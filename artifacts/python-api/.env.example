# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Database ---
# PostgreSQL connection string. Same database as the Node.js backend.
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/options_trader

# --- Fyers API ---
# Your Fyers app ID (permanent, does not change).
# Find it at: https://myapi.fyers.in/dashboard
FYERS_APP_ID=QWOKW94G0J-100

# Your Fyers access token (expires at midnight every day).
# Generate a new one each morning from the Fyers API dashboard.
# Leave empty to use the Black-Scholes simulator instead of live data.
FYERS_ACCESS_TOKEN=

# --- Server ---
# Port the Python API server listens on.
# Default: 8081 (Node.js backend uses 8080).
PORT=8081
